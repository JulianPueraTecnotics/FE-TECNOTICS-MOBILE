# Desarrollo local — copia a .env y ajusta puertos si hace falta
# EXPO_PUBLIC_* las embebe Metro; VITE_* las usa el sync (scripts/sync-expo-env.mjs)
# .env tiene prioridad sobre .env.local al sincronizar.

# Backend (MC-TECNOTICS-FACTURACION suele correr en 3001)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
VITE_APP_BACK_URL=http://localhost:3001

# Front Expo web (8081) o portal Vite (5173)
EXPO_PUBLIC_FE_URL=http://localhost:8081
VITE_APP_FE_URL=http://localhost:8081

# Producción (comentar las líneas de arriba y usar estas)
# EXPO_PUBLIC_API_BASE_URL=https://facturacionelectronicatt.tecnotics.co
# EXPO_PUBLIC_FE_URL=https://facturacionelectronicatt.tecnotics.co
VITE_APP_EPAYCO_PUBLIC_KEY=
VITE_APP_EPAYCO_CUSTOMER_ID=

# Turnstile (login web) — opcional; sin valor usa clave de prueba Cloudflare
# VITE_TURNSTILE_SITE_KEY=
# EXPO_PUBLIC_TURNSTILE_SITE_KEY=

# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3002
