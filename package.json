{
  "name": "fe-tecnotics-mobile",
  "main": "expo-router/entry",
  "version": "1.3.2",
  "private": true,
  "scripts": {
    "prestart": "node scripts/sync-expo-env.mjs && node scripts/patch-expo-logcontext.mjs",
    "start": "expo start",
    "start:clean": "expo start -c",
    "adb-reverse": "powershell -ExecutionPolicy Bypass -File scripts/adb-reverse.ps1",
    "android": "node scripts/sync-expo-env.mjs && node scripts/patch-expo-logcontext.mjs && powershell -ExecutionPolicy Bypass -File scripts/adb-reverse.ps1 && expo start --android",
    "start:tunnel": "node scripts/sync-expo-env.mjs && node scripts/patch-expo-logcontext.mjs && expo start --tunnel",
    "start:android:tunnel": "node scripts/sync-expo-env.mjs && node scripts/patch-expo-logcontext.mjs && expo start --tunnel --android",
    "turnstile:serve": "node scripts/turnstile-verify-server.mjs",
    "turnstile:tunnel": "node scripts/turnstile-verify-tunnel.mjs",
    "ios": "node scripts/sync-expo-env.mjs && node scripts/patch-expo-logcontext.mjs && expo start --ios",
    "web": "node scripts/sync-expo-env.mjs && node scripts/patch-expo-logcontext.mjs && expo start --web",
    "expo:config": "expo config --type public",
    "check-env": "node scripts/check-env.js",
    "sync-portal": "node scripts/sync-from-portal.mjs",
    "generate-brand-assets": "node scripts/generate-brand-assets.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "@tecnotics/fe-billing": "^1.9.30",
    "@tecnotics/fe-billing-native": "^0.1.3",
    "babel-preset-expo": "~54.0.10",
    "chart.js": "^4.5.1",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "5.4.296",
    "react": "19.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-native": "0.81.5",
    "react-native-color-matrix-image-filters": "^8.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-pdf": "^10.4.1",
    "react-router": "^7.18.0",
    "react-router-dom": "^7.18.0",
    "react-signature-canvas": "1.1.0-alpha.2",
    "semver": "^7.8.5",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "dotenv": "^17.4.1",
    "sharp": "^0.35.3",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "pdfjs-dist": "5.4.296"
  }
