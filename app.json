{
  "expo": {
    "name": "Tecnotics Contable",
    "slug": "tecnotics-contable-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "scheme": "tecnoticsmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#002737"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tecnotics.facturacion.mobile",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.tecnotics.facturacion.mobile",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#002737"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/favicon.png",
          "resizeMode": "contain",
          "backgroundColor": "#002737"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/51f6f6e2-0869-4190-bd66-a661850d4512"
    },
    "extra": {
      "eas": {
        "projectId": "51f6f6e2-0869-4190-bd66-a661850d4512"
      }
    }
  }
}
